{
  "name": "avatar",
  "type": "registry:ui",
  "title": "Avatar",
  "description": "espresso-ui Avatar component (Vue)",
  "dependencies": [
    "clsx",
    "tailwind-merge",
    "class-variance-authority",
    "@lucide/vue"
  ],
  "registryDependencies": [],
  "files": [
    {
      "path": "components/ui/Avatar.vue",
      "content": "<script setup lang=\"ts\">\nimport { computed, ref } from \"vue\";\nimport { cva, type VariantProps } from \"class-variance-authority\";\nimport { User } from \"@lucide/vue\";\nimport { cn } from \"@/lib/utils\";\n\nconst avatarFaceVariants = cva(\n  \"inline-flex shrink-0 items-center justify-center overflow-hidden bg-(--avatar-bg) font-medium text-(--avatar-fg)\",\n  {\n    variants: {\n      size: {\n        xs: \"size-(--avatar-xs-size) [font-size:var(--avatar-xs-font-size)] rounded-(--avatar-xs-radius)\",\n        sm: \"size-(--avatar-sm-size) [font-size:var(--avatar-sm-font-size)] rounded-(--avatar-sm-radius)\",\n        md: \"size-(--avatar-md-size) [font-size:var(--avatar-md-font-size)] rounded-(--avatar-md-radius)\",\n        lg: \"size-(--avatar-lg-size) [font-size:var(--avatar-lg-font-size)] rounded-(--avatar-lg-radius)\",\n        xl: \"size-(--avatar-xl-size) [font-size:var(--avatar-xl-font-size)] rounded-(--avatar-xl-radius)\",\n        \"2xl\":\n          \"size-(--avatar-2xl-size) [font-size:var(--avatar-2xl-font-size)] rounded-(--avatar-2xl-radius)\",\n        \"3xl\":\n          \"size-(--avatar-3xl-size) [font-size:var(--avatar-3xl-font-size)] rounded-(--avatar-3xl-radius)\",\n      },\n      shape: {\n        squircle: \"\",\n        circle: \"!rounded-full\",\n      },\n    },\n    defaultVariants: {\n      size: \"md\",\n      shape: \"squircle\",\n    },\n  },\n);\n\ntype AvatarVariants = VariantProps<typeof avatarFaceVariants>;\n\nconst fallbackIconSizeClasses: Record<NonNullable<AvatarVariants[\"size\"]>, string> = {\n  xs: \"[width:var(--avatar-xs-icon-size)] [height:var(--avatar-xs-icon-size)]\",\n  sm: \"[width:var(--avatar-sm-icon-size)] [height:var(--avatar-sm-icon-size)]\",\n  md: \"[width:var(--avatar-md-icon-size)] [height:var(--avatar-md-icon-size)]\",\n  lg: \"[width:var(--avatar-lg-icon-size)] [height:var(--avatar-lg-icon-size)]\",\n  xl: \"[width:var(--avatar-xl-icon-size)] [height:var(--avatar-xl-icon-size)]\",\n  \"2xl\": \"[width:var(--avatar-2xl-icon-size)] [height:var(--avatar-2xl-icon-size)]\",\n  \"3xl\": \"[width:var(--avatar-3xl-icon-size)] [height:var(--avatar-3xl-icon-size)]\",\n};\n\nconst props = withDefaults(\n  defineProps<{\n    src?: string;\n    alt?: string;\n    fallback?: string;\n    size?: AvatarVariants[\"size\"];\n    shape?: AvatarVariants[\"shape\"];\n    class?: string;\n  }>(),\n  {\n    src: \"\",\n    alt: \"\",\n    fallback: \"\",\n    size: \"md\",\n    shape: \"squircle\",\n  },\n);\n\nconst imageError = ref(false);\nconst faceClasses = computed(() => avatarFaceVariants({ size: props.size, shape: props.shape }));\nconst rootClasses = computed(() => cn(\"relative inline-flex shrink-0 select-none\", props.class));\nconst showImage = computed(() => Boolean(props.src) && !imageError.value);\nconst initials = computed(() => props.fallback.trim().slice(0, 2));\nconst label = computed(() => props.alt || initials.value || \"User avatar\");\n\nfunction onImageError(): void {\n  imageError.value = true;\n}\n</script>\n\n<template>\n  <span\n    role=\"img\"\n    :aria-label=\"label\"\n    :data-size=\"props.size\"\n    :data-shape=\"props.shape\"\n    :class=\"rootClasses\"\n    v-bind=\"$attrs\"\n  >\n    <span :class=\"faceClasses\">\n      <img\n        v-if=\"showImage\"\n        :src=\"props.src\"\n        :alt=\"props.alt\"\n        class=\"size-full object-cover\"\n        @error=\"onImageError\"\n      />\n      <span v-else-if=\"initials\" aria-hidden=\"true\">{{ initials }}</span>\n      <User\n        v-else\n        :class=\"cn(fallbackIconSizeClasses[props.size!], 'text-(--color-muted-foreground)')\"\n        aria-hidden=\"true\"\n      />\n    </span>\n    <slot name=\"status\" />\n  </span>\n</template>\n",
      "type": "registry:ui"
    },
    {
      "path": "components/ui/avatar.css",
      "content": "/* Avatar component tokens — override these to customise avatars. */\n:root {\n  /* Per-size dimensions */\n  --avatar-xs-size: 16px;\n  --avatar-sm-size: 20px;\n  --avatar-md-size: 24px;\n  --avatar-lg-size: 28px;\n  --avatar-xl-size: 32px;\n  --avatar-2xl-size: 40px;\n  --avatar-3xl-size: 46px;\n\n  /* Per-size squircle radii */\n  --avatar-xs-radius: 4px;\n  --avatar-sm-radius: 5px;\n  --avatar-md-radius: 5px;\n  --avatar-lg-radius: 6px;\n  --avatar-xl-radius: 6px;\n  --avatar-2xl-radius: 8px;\n  --avatar-3xl-radius: 8px;\n\n  /* Per-size initials font sizes */\n  --avatar-xs-font-size: 11px;\n  --avatar-sm-font-size: 13px;\n  --avatar-md-font-size: 14px;\n  --avatar-lg-font-size: 14px;\n  --avatar-xl-font-size: 16px;\n  --avatar-2xl-font-size: 18px;\n  --avatar-3xl-font-size: 20px;\n\n  /* Per-size fallback icon sizes */\n  --avatar-xs-icon-size: 10px;\n  --avatar-sm-icon-size: 12px;\n  --avatar-md-icon-size: 14px;\n  --avatar-lg-icon-size: 16px;\n  --avatar-xl-icon-size: 18px;\n  --avatar-2xl-icon-size: 22px;\n  --avatar-3xl-icon-size: 24px;\n\n  /* Surfaces */\n  --avatar-bg: var(--color-muted);\n  --avatar-fg: var(--color-foreground);\n}\n",
      "type": "registry:style"
    }
  ]
}