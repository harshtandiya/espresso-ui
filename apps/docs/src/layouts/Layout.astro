---
import "@/styles/globals.css";
import Sidebar from "@/components/Sidebar.astro";
import MobileShell from "@/components/mobile/MobileShell.astro";
import MobileDetailNav from "@/components/mobile/MobileDetailNav.astro";
import { INTRO_SECTION_IDS, MOBILE_BP, MOBILE_NAV_SECTIONS } from "@/lib/sections";

interface Props {
  title?: string;
  description?: string;
}

const { title = "espresso-ui", description = "A small, opinionated UI kit for internal tools." } =
  Astro.props;

const mobileNavSectionIds = MOBILE_NAV_SECTIONS.map((s) => s.id);
const introSectionIds = [...INTRO_SECTION_IDS];
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <script is:inline define:vars={{ MOBILE_BP, mobileNavSectionIds, introSectionIds }}>
      // Apply persisted theme before paint to avoid flash
      try {
        const stored = localStorage.getItem("theme");
        const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        const theme = stored ?? (prefersDark ? "dark" : "light");
        document.documentElement.setAttribute("data-theme", theme);
      } catch {
        /* localStorage may be unavailable */
      }

      const mobileMq = window.matchMedia(`(max-width: ${MOBILE_BP}px)`);

      function isMobile() {
        return mobileMq.matches;
      }

      function setMobileMode(on) {
        document.body.toggleAttribute("data-mobile", on);
        if (!on) {
          document.body.removeAttribute("data-mobile-screen");
          document.querySelectorAll("#pane-right section[id]").forEach((s) => {
            s.removeAttribute("data-mobile-active");
            s.removeAttribute("hidden");
          });
          const detailNav = document.querySelector("[data-mobile-detail-nav]");
          if (detailNav) detailNav.hidden = true;
        } else {
          document.body.dataset.mobileScreen =
            document.body.dataset.mobileScreen ?? "index";
          syncMobileSections(document.body.dataset.mobileSelected ?? null);
        }
      }

      function syncMobileSections(id) {
        const sections = document.querySelectorAll("#pane-right section[id]");
        sections.forEach((s) => {
          const active = !!id && s.id === id;
          s.toggleAttribute("data-mobile-active", active);
        });
        const detailNav = document.querySelector("[data-mobile-detail-nav]");
        const counter = document.querySelector("[data-mobile-counter]");
        if (detailNav) detailNav.hidden = !id;
        if (counter) {
          if (id) {
            const idx = mobileNavSectionIds.indexOf(id);
            counter.textContent = `${String(idx + 1).padStart(2, "0")} / ${String(mobileNavSectionIds.length).padStart(2, "0")}`;
          } else {
            counter.textContent = "";
          }
        }
      }

      function openMobileSection(id, { push = true } = {}) {
        if (introSectionIds.includes(id)) {
          closeMobileSection({ push });
          return;
        }
        if (!mobileNavSectionIds.includes(id)) return;
        document.body.dataset.mobileSelected = id;
        document.body.dataset.mobileScreen = "detail";
        syncMobileSections(id);
        if (push) {
          history.pushState({ mobileSection: id }, "", `#${id}`);
        }
        const pane = document.getElementById("pane-right");
        if (pane) pane.scrollTop = 0;
      }

      function closeMobileSection({ push = true } = {}) {
        delete document.body.dataset.mobileSelected;
        document.body.dataset.mobileScreen = "index";
        syncMobileSections(null);
        if (push) {
          history.pushState({ mobileSection: null }, "", window.location.pathname);
        }
      }

      function syncFromHash() {
        if (!isMobile()) return;
        const hash = window.location.hash.replace(/^#/, "");
        if (hash && introSectionIds.includes(hash)) {
          closeMobileSection({ push: false });
        } else if (hash && mobileNavSectionIds.includes(hash)) {
          openMobileSection(hash, { push: false });
        } else {
          closeMobileSection({ push: false });
        }
      }

      mobileMq.addEventListener("change", () => {
        setMobileMode(isMobile());
        if (isMobile()) syncFromHash();
      });

      document.addEventListener("DOMContentLoaded", () => {
        setMobileMode(isMobile());
        if (isMobile()) {
          const preset = document.body.dataset.mobileSelected;
          if (preset) {
            document.body.dataset.mobileScreen = "detail";
            syncMobileSections(preset);
          } else {
            syncFromHash();
          }
        }
      });

      window.__mobileNav = { openMobileSection, closeMobileSection, isMobile, syncFromHash };
    </script>
  </head>
  <body data-mobile-screen="index">
    <script is:inline define:vars={{ MOBILE_BP, mobileNavSectionIds, introSectionIds }}>
      if (window.matchMedia(`(max-width: ${MOBILE_BP}px)`).matches) {
        document.body.setAttribute("data-mobile", "");
        const hash = window.location.hash.replace(/^#/, "");
        if (hash && mobileNavSectionIds.includes(hash)) {
          document.body.dataset.mobileScreen = "detail";
          document.body.dataset.mobileSelected = hash;
        }
      }
    </script>
    <div class="app-shell">
      <Sidebar />
      <div class="main-column">
        <MobileShell />
        <MobileDetailNav />
        <main id="pane-right" class="scroll-pane pane-right">
          <slot />
        </main>
      </div>
    </div>

    <script is:inline>
      // Active-section tracking — desktop split-pane nav highlight
      const right = document.getElementById("pane-right");
      if (right) {
        const sections = right.querySelectorAll("section[id]");
        const io = new IntersectionObserver(
          (entries) => {
            if (window.__mobileNav?.isMobile()) return;
            const visible = entries
              .filter((e) => e.isIntersecting)
              .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
            if (visible[0]) {
              const id = visible[0].target.id;
              document.querySelectorAll("[data-nav-item]").forEach((el) => {
                el.toggleAttribute("data-active", el.getAttribute("data-nav-item") === id);
              });
            }
          },
          { root: right, rootMargin: "0px 0px -70% 0px", threshold: 0 },
        );
        sections.forEach((s) => io.observe(s));
      }

      // Desktop jump-to-section + mobile push-nav picks
      document.querySelectorAll("[data-nav-item]").forEach((btn) => {
        btn.addEventListener("click", () => {
          const id = btn.getAttribute("data-nav-item");
          if (!id) return;
          if (window.__mobileNav?.isMobile()) {
            window.__mobileNav.openMobileSection(id);
            return;
          }
          const el = document.getElementById(id);
          if (el) el.scrollIntoView({ behavior: "smooth", block: "start" });
        });
      });

      document.querySelectorAll("[data-mobile-pick]").forEach((btn) => {
        btn.addEventListener("click", () => {
          const id = btn.getAttribute("data-mobile-pick");
          if (id) window.__mobileNav?.openMobileSection(id);
        });
      });

      document.querySelector("[data-mobile-back]")?.addEventListener("click", () => {
        window.__mobileNav?.closeMobileSection();
      });

      document.querySelector("[data-mobile-home]")?.addEventListener("click", (e) => {
        if (!window.__mobileNav?.isMobile()) return;
        e.preventDefault();
        window.__mobileNav?.closeMobileSection();
      });

      window.addEventListener("popstate", () => {
        if (window.__mobileNav?.isMobile()) window.__mobileNav.syncFromHash();
      });

      // Theme toggle (desktop footer + mobile top nav)
      function bindThemeToggle(id) {
        const toggle = document.getElementById(id);
        if (!toggle) return;
        toggle.addEventListener("click", () => {
          const cur = document.documentElement.getAttribute("data-theme") ?? "light";
          const next = cur === "dark" ? "light" : "dark";
          document.documentElement.setAttribute("data-theme", next);
          try {
            localStorage.setItem("theme", next);
          } catch {
            /* noop */
          }
        });
      }
      bindThemeToggle("theme-toggle");
      bindThemeToggle("mobile-theme-toggle");

      document.querySelectorAll("[data-copy-cmd]").forEach((btn) => {
        btn.addEventListener("click", async () => {
          const cmd = btn.getAttribute("data-copy-cmd");
          if (!cmd) return;
          try {
            await navigator.clipboard.writeText(cmd);
            btn.setAttribute("data-copied", "");
            window.setTimeout(() => btn.removeAttribute("data-copied"), 1400);
          } catch {
            /* clipboard unavailable */
          }
        });
      });

      // Mobile index scroll → topnav border
      const indexScroll = document.querySelector("[data-mobile-index-scroll]");
      const topnav = document.querySelector("[data-mobile-topnav]");
      indexScroll?.addEventListener("scroll", () => {
        topnav?.toggleAttribute("data-scrolled", (indexScroll.scrollTop ?? 0) > 8);
      });
    </script>
  </body>
</html>
