---
import { SITE_VERSION } from "@/lib/site-copy";
// Overview / hero panel — no Panel wrapper since it has bespoke type scale
---

<section id="overview" class="detail hero-panel">
  <div class="eyebrow">
    <span class="dot"></span> {SITE_VERSION} — early preview
  </div>
  <h2>A small, opinionated UI&nbsp;kit for <em>internal&nbsp;tools</em>.</h2>
  <p class="desc">
    Carefully-tuned React and Vue components, two themes, and a handful of tokens. Designed for
    clarity, not flash. Drop into any project; everything ships as copy-pasted source you can
    override token by token.
  </p>
</section>

<style>
  .detail {
    padding: 64px 64px 96px;
    max-width: 880px;
  }
  .hero-panel {
    padding-top: 84px;
  }
  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-ink-3);
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    padding: 5px 10px;
    border-radius: 999px;
    margin-bottom: 24px;
  }
  .eyebrow .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-ink-3);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-ink-3) 18%, transparent);
  }
  h2 {
    font-size: clamp(40px, 4.5vw, 64px);
    line-height: 1.02;
    font-weight: 600;
    letter-spacing: -0.025em;
    margin: 0;
    color: var(--color-ink-1);
    text-wrap: balance;
  }
  h2 em {
    font-style: normal;
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: 0.86em;
    color: var(--color-ink-3);
  }
  .desc {
    margin: 14px 0 0;
    font-size: 16px;
    line-height: 1.55;
    color: var(--color-ink-3);
    max-width: 600px;
  }
  @media (max-width: 768px) {
    .detail {
      padding: 32px 24px;
    }
  }
</style>
