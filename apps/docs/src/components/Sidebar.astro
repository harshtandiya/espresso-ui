---
import { SECTIONS, GROUPS, sectionNumber } from "@/lib/sections";
---

<aside class="pane-left scroll-pane">
  <div class="topbar">
    <a class="wordmark" href="#overview">
      <span class="glyph">e</span> espresso-ui
    </a>
    <span class="ver">v0.1</span>
  </div>

  <h1 class="display">A small, opinionated UI&nbsp;kit for internal&nbsp;tools.</h1>
  <p class="lede">
    A carefully-tuned component library for React and Vue. Two themes, a handful of tokens, copy
    components straight into your project. Click anything below to jump to its details.
  </p>

  <div class="install">
    <span class="dollar">$</span>
    <code>
      <span class="tok-cmd">npx </span>espresso-ui<span class="tok-arg"> init</span>
    </code>
    <button class="install-btn" data-nav-item="install" type="button">Read</button>
  </div>

  {
    GROUPS.map((g) => {
      const items = SECTIONS.filter((s) => s.group === g.key);
      if (items.length === 0) return null;
      return (
        <div>
          {g.label ? <div class="label">{g.label}</div> : <div class="label-spacer" />}
          <div class:list={["index-grid", g.key === "components" ? "two-col" : "one-col"]}>
            {items.map((s) => (
              <button class="index-item" type="button" data-nav-item={s.id}>
                <span>{s.label}</span>
                <span class="num">{sectionNumber(s.id)}</span>
              </button>
            ))}
          </div>
        </div>
      );
    })
  }

  <div class="meta-row">
    <div>MIT licensed · TypeScript · React + Vue</div>
    <div>
      <a href="https://github.com/anthropics/espresso-ui">View source on GitHub</a>
    </div>
  </div>

  <div class="left-foot">
    <span>© 2026 espresso-ui</span>
    <button id="theme-toggle" class="theme-toggle" aria-label="Toggle theme" type="button">
      <svg
        class="icon-moon"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.6"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><path d="M21 12.79A9 9 0 1 1 11.21 3a7 7 0 0 0 9.79 9.79z"></path></svg
      >
      <svg
        class="icon-sun"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.6"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><circle cx="12" cy="12" r="4"></circle><path
          d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"
        ></path></svg
      >
    </button>
  </div>
</aside>

<style>
  .pane-left {
    height: 100vh;
    overflow-y: auto;
    padding: 56px;
    border-right: 1px solid var(--color-line-2);
    background: var(--color-surface);
  }
  .topbar {
    display: flex;
    align-items: center;
    gap: 22px;
    margin-bottom: 56px;
  }
  .wordmark {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-weight: 600;
    font-size: 14px;
    color: var(--color-ink-1);
    text-decoration: none;
  }
  .wordmark .glyph {
    width: 22px;
    height: 22px;
    border-radius: 6px;
    background: var(--color-ink-1);
    color: var(--color-surface);
    display: grid;
    place-items: center;
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 700;
  }
  .ver {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-ink-5);
  }

  .display {
    font-size: clamp(36px, 3.5vw, 52px);
    font-weight: 600;
    letter-spacing: -0.025em;
    line-height: 1.05;
    margin: 0;
    color: var(--color-ink-1);
    text-wrap: balance;
  }
  .lede {
    font-size: 16px;
    line-height: 1.55;
    color: var(--color-ink-3);
    max-width: 460px;
    margin: 28px 0 0;
    text-wrap: pretty;
  }

  .install {
    margin-top: 36px;
    border: 1px solid var(--color-line);
    border-radius: 10px;
    padding: 4px 4px 4px 12px;
    background: var(--color-surface-2);
    display: flex;
    align-items: center;
    gap: 10px;
    max-width: 460px;
  }
  .install .dollar {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--color-ink-4);
  }
  .install code {
    flex: 1;
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--color-ink-1);
    overflow-x: auto;
    white-space: nowrap;
  }
  .install code .tok-cmd {
    color: var(--color-ink-4);
  }
  .install code .tok-arg {
    color: var(--color-ink-3);
  }
  .install-btn {
    background: transparent;
    border: none;
    font: inherit;
    font-size: 13px;
    color: var(--color-ink-3);
    padding: 4px 10px;
    border-radius: 6px;
    cursor: pointer;
  }
  .install-btn:hover {
    color: var(--color-ink-1);
    background: var(--color-surface-3);
  }

  .label {
    font-size: 13px;
    color: var(--color-ink-4);
    margin: 44px 0 14px;
  }
  .label-spacer {
    height: 24px;
  }

  .index-grid {
    display: grid;
    gap: 4px 24px;
  }
  .index-grid.one-col {
    grid-template-columns: 1fr;
  }
  .index-grid.two-col {
    grid-template-columns: 1fr 1fr;
  }

  .index-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    padding: 5px 0;
    font-size: 15px;
    color: var(--color-ink-3);
    background: none;
    border: none;
    text-align: left;
    cursor: pointer;
    font-family: inherit;
    transition: color 0.12s;
  }
  .index-item .num {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-ink-5);
    font-variant-numeric: tabular-nums;
  }
  .index-item:hover {
    color: var(--color-ink-1);
  }
  .index-item[data-active] {
    color: var(--color-ink-1);
    font-weight: 500;
  }
  .index-item[data-active] .num {
    color: var(--color-ink-1);
  }

  .meta-row {
    margin-top: 28px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    font-size: 13px;
    color: var(--color-ink-4);
    line-height: 1.5;
  }
  .meta-row a {
    color: var(--color-ink-3);
    text-decoration: underline;
    text-decoration-color: var(--color-line);
    text-underline-offset: 3px;
  }
  .meta-row a:hover {
    color: var(--color-ink-1);
    text-decoration-color: var(--color-ink-5);
  }

  .left-foot {
    margin-top: 56px;
    padding-top: 22px;
    border-top: 1px solid var(--color-line-2);
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 12px;
    color: var(--color-ink-5);
  }
  .theme-toggle {
    width: 30px;
    height: 30px;
    display: inline-grid;
    place-items: center;
    border: 1px solid var(--color-line);
    border-radius: 8px;
    background: var(--color-surface);
    color: var(--color-ink-3);
    cursor: pointer;
  }
  .theme-toggle:hover {
    color: var(--color-ink-1);
    border-color: var(--color-ink-5);
  }
  .theme-toggle svg {
    width: 14px;
    height: 14px;
  }
  /* Show one icon based on theme */
  .icon-sun {
    display: none;
  }
  :global(html[data-theme="dark"]) .icon-sun {
    display: block;
  }
  :global(html[data-theme="dark"]) .icon-moon {
    display: none;
  }

  @media (max-width: 880px) {
    .pane-left {
      height: auto;
      overflow: visible;
      padding: 32px;
      border-right: none;
      border-bottom: 1px solid var(--color-line-2);
    }
    .index-grid.two-col {
      grid-template-columns: 1fr;
    }
  }
</style>
