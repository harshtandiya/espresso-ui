---
import { GROUPS, SECTIONS, sectionNumber } from "@/lib/sections";
import { footer, hero } from "@/lib/site-copy";
import Wordmark from "@/components/shared/Wordmark.astro";
import InstallBar from "@/components/shared/InstallBar.astro";
import ThemeToggle from "@/components/shared/ThemeToggle.astro";
---

<aside class="pane-left scroll-pane">
  <div class="topbar">
    <Wordmark href="#overview" versionAlign="end" />
  </div>

  <h1 class="display">{hero.title}</h1>
  <p class="lede">{hero.lede}</p>

  <div class="install-wrap">
    <InstallBar action="read" />
  </div>

  {
    GROUPS.map((g) => {
      const items = SECTIONS.filter((s) => s.group === g.key);
      if (items.length === 0) return null;
      return (
        <div>
          {g.label ? <div class="label">{g.label}</div> : <div class="label-spacer" />}
          <div class:list={["index-grid", g.key === "components" ? "two-col" : "one-col"]}>
            {items.map((s) => (
              <button class="index-item" type="button" data-nav-item={s.id}>
                <span>{s.label}</span>
                <span class="num">{sectionNumber(s.id)}</span>
              </button>
            ))}
          </div>
        </div>
      );
    })
  }

  <div class="meta-row">
    <div>{footer.license}</div>
    <div>
      <a href={footer.github}>{footer.githubLabel}</a>
    </div>
  </div>

  <div class="left-foot">
    <span>{footer.copyright}</span>
    <ThemeToggle id="theme-toggle" />
  </div>
</aside>

<style>
  .pane-left {
    height: 100vh;
    overflow-y: auto;
    padding: 56px;
    border-right: 1px solid var(--color-line-2);
    background: var(--color-surface);
  }
  .topbar {
    display: flex;
    align-items: center;
    gap: 22px;
    margin-bottom: 56px;
  }

  .display {
    font-size: clamp(36px, 3.5vw, 52px);
    font-weight: 600;
    letter-spacing: -0.025em;
    line-height: 1.05;
    margin: 0;
    color: var(--color-ink-1);
    text-wrap: balance;
  }
  .lede {
    font-size: 16px;
    line-height: 1.55;
    color: var(--color-ink-3);
    max-width: 460px;
    margin: 28px 0 0;
    text-wrap: pretty;
  }

  .install-wrap {
    margin-top: 36px;
    max-width: 460px;
  }

  .label {
    font-size: 13px;
    color: var(--color-ink-4);
    margin: 44px 0 14px;
  }
  .label-spacer {
    height: 24px;
  }

  .index-grid {
    display: grid;
    gap: 4px 24px;
  }
  .index-grid.one-col {
    grid-template-columns: 1fr;
  }
  .index-grid.two-col {
    grid-template-columns: 1fr 1fr;
  }

  .index-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    padding: 5px 0;
    font-size: 15px;
    color: var(--color-ink-3);
    background: none;
    border: none;
    text-align: left;
    cursor: pointer;
    font-family: inherit;
    transition: color 0.12s;
  }
  .index-item .num {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-ink-5);
    font-variant-numeric: tabular-nums;
  }
  .index-item:hover {
    color: var(--color-ink-1);
  }
  .index-item[data-active] {
    color: var(--color-ink-1);
    font-weight: 500;
  }
  .index-item[data-active] .num {
    color: var(--color-ink-1);
  }

  .meta-row {
    margin-top: 28px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    font-size: 13px;
    color: var(--color-ink-4);
    line-height: 1.5;
  }
  .meta-row a {
    color: var(--color-ink-3);
    text-decoration: underline;
    text-decoration-color: var(--color-line);
    text-underline-offset: 3px;
  }
  .meta-row a:hover {
    color: var(--color-ink-1);
    text-decoration-color: var(--color-ink-5);
  }

  .left-foot {
    margin-top: 56px;
    padding-top: 22px;
    border-top: 1px solid var(--color-line-2);
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 12px;
    color: var(--color-ink-5);
  }
</style>
