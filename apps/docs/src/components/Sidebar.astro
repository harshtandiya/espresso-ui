---
const links = [
  {
    section: "Guide",
    items: [
      { href: "/", label: "Introduction" },
      { href: "/getting-started", label: "Getting Started" },
    ],
  },
  {
    section: "Components",
    items: [{ href: "/components/button", label: "Button" }],
  },
];

const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<aside class="w-60 shrink-0 border-r border-(--color-border) px-6 py-10 sticky top-0 h-dvh">
  <a href="/" class="block text-lg font-semibold mb-8">espresso-ui</a>
  <nav class="space-y-6 text-sm">
    {
      links.map(({ section, items }) => (
        <div>
          <h3 class="text-xs uppercase tracking-wide text-(--color-fg-muted) mb-2">{section}</h3>
          <ul class="space-y-1">
            {items.map(({ href, label }) => {
              const active = pathname === href;
              return (
                <li>
                  <a
                    href={href}
                    class:list={[
                      "block rounded px-2 py-1",
                      active
                        ? "bg-(--color-bg-muted) text-(--color-fg)"
                        : "text-(--color-fg-muted) hover:text-(--color-fg)",
                    ]}
                  >
                    {label}
                  </a>
                </li>
              );
            })}
          </ul>
        </div>
      ))
    }
  </nav>
</aside>
