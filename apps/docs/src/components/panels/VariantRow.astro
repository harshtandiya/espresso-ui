---
interface Props {
  label: string;
  sub?: string;
}

const { label, sub } = Astro.props;
---

<div
  class="variant-row contents max-md:block max-md:py-3.5 max-md:border-b max-md:border-(--color-line-2) max-md:last:border-b-0"
>
  <div
    class="variant-label py-[18px] border-b border-(--color-line-2) text-[13px] font-medium text-(--color-ink-1) max-md:py-0 max-md:border-b-0"
  >
    {label}
    {
      sub && (
        <span class="sub block font-normal text-(--color-ink-4) text-xs mt-1 leading-snug max-md:text-[11px] max-md:[font-family:var(--font-mono)] max-md:mb-2.5">
          {sub}
        </span>
      )
    }
  </div>
  <div
    class="variant-cell py-[18px] border-b border-(--color-line-2) flex flex-wrap items-center justify-end gap-3 max-md:py-0 max-md:border-b-0 max-md:gap-2.5"
  >
    <slot />
  </div>
</div>
