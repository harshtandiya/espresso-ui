---
interface Props {
  group?: string;
  label: string;
}

const { group, label } = Astro.props;
---

<div class="crumb">
  {group && <span>{group}</span>}
  {group && <span>·</span>}
  <b>{label}</b>
</div>

<style>
  .crumb {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-ink-5);
    margin-bottom: 8px;
  }
  .crumb b {
    color: var(--color-ink-3);
    font-weight: 500;
  }
</style>
