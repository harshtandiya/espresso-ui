---
interface Props {
  group?: string;
  label: string;
}

const { group, label } = Astro.props;
---

<div
  class="flex items-center gap-1.5 [font-family:var(--font-mono)] text-[11px] text-(--color-ink-5) mb-2"
>
  {group && <span>{group}</span>}
  {group && <span>·</span>}
  <b class="text-(--color-ink-3) font-medium">{label}</b>
</div>
