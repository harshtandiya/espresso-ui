---
import type { SectionStatus } from "@/lib/sections";

interface Props {
  status?: SectionStatus;
  file: string;
}

const { status = "stable", file } = Astro.props;

const statusColor: Record<SectionStatus, string> = {
  stable: "rgb(31, 138, 91)",
  beta: "rgb(82, 82, 82)",
  new: "rgb(0, 123, 224)",
};
---

<div
  class="detail-meta mt-6 mb-0 flex items-center gap-4 flex-wrap text-xs text-(--color-ink-4) max-md:mt-3.5 max-md:gap-0 max-md:flex-nowrap max-md:text-[11px] max-md:[font-family:var(--font-mono)] max-md:p-0"
>
  <span
    class="status inline-flex items-center gap-1.5 py-0.5 px-2 rounded-full border border-(--color-line) bg-(--color-surface-2) capitalize max-md:border-0 max-md:bg-transparent max-md:p-0 max-md:gap-[5px] max-md:uppercase"
  >
    <span
      class="pip size-1.5 rounded-full shrink-0 max-md:size-[5px]"
      style={`background: ${statusColor[status]}`}
    />
    {status}
  </span>
  <span class="dot size-[3px] rounded-full bg-(--color-ink-5) max-md:mx-1.5" />
  <span class="file [font-family:var(--font-mono)]">{file}</span>
  <span class="dot desktop-only size-[3px] rounded-full bg-(--color-ink-5) max-md:mx-1.5" />
  <span class="desktop-only max-md:hidden">Headless API</span>
</div>
