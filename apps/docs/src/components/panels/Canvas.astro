---
interface Props {
  grid?: boolean;
  padded?: boolean;
  class?: string;
}

const { grid = true, padded = true, class: className = "" } = Astro.props;
---

<div
  class:list={[
    "canvas relative overflow-hidden border border-(--color-line) bg-(--color-surface) rounded-xl flex items-center justify-center min-h-56 mt-3 max-md:mx-[var(--mobile-gutter,20px)] max-md:mt-0 max-md:min-h-36",
    grid && "canvas-grid",
    padded && "py-14 px-8 max-md:py-8 max-md:px-4",
    className,
  ]}
>
  <div
    class="canvas-content relative z-10 flex flex-wrap items-center justify-center gap-4 rounded-2xl bg-(--color-surface)/75 px-8 py-6 backdrop-blur-md max-md:px-5 max-md:py-4"
  >
    <slot />
  </div>
</div>

<style>
  .canvas-grid::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background-image:
      linear-gradient(var(--color-line-2) 1px, transparent 1px),
      linear-gradient(90deg, var(--color-line-2) 1px, transparent 1px);
    background-size: 16px 16px;
    background-position: -1px -1px;
    mask-image: radial-gradient(
      ellipse 90% 80% at 50% 50%,
      transparent 0%,
      transparent 26%,
      black 82%
    );
    -webkit-mask-image: radial-gradient(
      ellipse 90% 80% at 50% 50%,
      transparent 0%,
      transparent 25%,
      black 82%
    );
  }

  @media (max-width: 768px) {
    .canvas-grid::before {
      background-size: 14px 14px;
      mask-image: radial-gradient(
        ellipse 95% 85% at 50% 50%,
        transparent 0%,
        transparent 22%,
        black 78%
      );
      -webkit-mask-image: radial-gradient(
        ellipse 95% 85% at 50% 50%,
        transparent 0%,
        transparent 22%,
        black 78%
      );
    }
  }
</style>
