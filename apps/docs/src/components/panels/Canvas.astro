---
interface Props {
  grid?: boolean;
  padded?: boolean;
  class?: string;
}

const { grid = true, padded = true, class: className = "" } = Astro.props;
---

<div
  class:list={[
    "border border-(--color-line) bg-(--color-surface) rounded-[14px] flex flex-wrap gap-[18px] items-center justify-center min-h-[220px] mt-3 max-md:mx-[var(--mobile-gutter,20px)] max-md:mt-0 max-md:min-h-[140px] max-md:rounded-xl max-md:gap-3",
    padded && "py-14 px-8 max-md:py-8 max-md:px-4",
    grid && "canvas-grid",
    className,
  ]}
>
  <slot />
</div>

<style>
  .canvas-grid {
    background-image:
      linear-gradient(var(--color-line-2) 1px, transparent 1px),
      linear-gradient(90deg, var(--color-line-2) 1px, transparent 1px);
    background-size: 16px 16px;
    background-position: -1px -1px;
  }

  @media (max-width: 768px) {
    .canvas-grid {
      background-size: 14px 14px;
    }
  }
</style>
