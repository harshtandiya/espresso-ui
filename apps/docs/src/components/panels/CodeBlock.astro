---
import { Code } from "astro:components";
import type { BuiltinLanguage } from "shiki";

interface Props {
  file?: string;
  lang?: BuiltinLanguage;
  code: string;
  flat?: boolean;
}

const { file, lang = "tsx", code, flat = false } = Astro.props;
---

<div class:list={["code", flat && "code-flat"]}>
  {
    file && (
      <div class="code-head">
        <span class="file">{file}</span>
      </div>
    )
  }
  <Code
    code={code}
    lang={lang}
    themes={{ light: "github-light", dark: "github-dark" }}
    defaultColor={false}
  />
</div>

<style>
  .code {
    margin-top: 28px;
    border: 1px solid var(--color-line);
    border-radius: 10px;
    background: var(--color-surface);
    overflow: hidden;
  }
  .code-flat {
    margin-top: 0;
    border: none;
    border-radius: 0;
    background: transparent;
  }
  .code-flat .code-head {
    border-top: 1px solid var(--color-line-2);
  }
  .code-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 7px 10px;
    border-bottom: 1px solid var(--color-line-2);
    background: var(--color-surface-2);
  }
  .code-head .file {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-ink-3);
  }
  .code :global(pre) {
    margin: 0;
    padding: 12px 14px;
    font-family: var(--font-mono);
    font-size: 11.5px;
    line-height: 1.55;
    overflow-x: auto;
    background: transparent !important;
    color: var(--shiki-light);
  }
  .code :global(pre span) {
    color: var(--shiki-light);
  }
  :global(html[data-theme="dark"]) .code :global(pre),
  :global(html[data-theme="dark"]) .code :global(pre span) {
    color: var(--shiki-dark);
  }

  @media (max-width: 768px) {
    .code {
      margin: 18px var(--mobile-gutter, 20px) 24px;
    }
  }
</style>
