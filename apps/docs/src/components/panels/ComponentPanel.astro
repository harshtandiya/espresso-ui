---
import Panel from "./Panel.astro";
import DetailMeta from "./DetailMeta.astro";
import CodeBlock from "./CodeBlock.astro";
import FrameworkCodeBlock from "./FrameworkCodeBlock.astro";
import type { SectionStatus } from "@/lib/sections";

interface Props {
  id: string;
  num: string;
  label: string;
  desc: string;
  status?: SectionStatus;
  code?: string;
  codeFile?: string;
  codeLang?: "tsx" | "vue" | "ts";
  codeVue?: string;
  codeVueFile?: string;
}

const {
  id,
  num,
  label,
  desc,
  status = "stable",
  code,
  codeFile,
  codeLang = "tsx",
  codeVue,
  codeVueFile,
} = Astro.props;

const file = codeFile ?? `${label.toLowerCase()}.tsx`;
const vueFile = codeVueFile ?? `${label.toLowerCase()}.vue`;
---

<Panel id={id} num={num} group="Components" label={label} desc={desc}>
  <DetailMeta slot="meta" status={status} file={file} />
  <slot />
  {
    code && codeVue ? (
      <FrameworkCodeBlock
        reactCode={code}
        vueCode={codeVue}
        reactFile={file}
        vueFile={vueFile}
      />
    ) : (
      code && <CodeBlock file={file} lang={codeLang} code={code} />
    )
  }
</Panel>
