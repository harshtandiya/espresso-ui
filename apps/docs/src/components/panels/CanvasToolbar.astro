---
interface Props {
  title: string;
  meta?: string;
}

const { title, meta } = Astro.props;
---

<div
  class="flex items-center justify-between mt-9 mb-2.5 max-md:items-baseline max-md:m-0 max-md:px-[var(--mobile-gutter,20px)] max-md:pt-6 max-md:pb-2.5"
>
  <h3
    class="m-0 text-[13px] font-medium text-(--color-ink-1) tracking-tight max-md:text-[11px] max-md:font-normal max-md:uppercase max-md:tracking-[0.08em] max-md:text-(--color-ink-4) max-md:[font-family:var(--font-mono)]"
  >
    {title}
  </h3>
  {
    meta && (
      <span class="[font-family:var(--font-mono)] text-[11px] text-(--color-ink-5) max-md:normal-case max-md:tracking-normal">
        {meta}
      </span>
    )
  }
</div>
