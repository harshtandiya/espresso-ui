---
import Crumb from "./Crumb.astro";

interface Props {
  id: string;
  num: string;
  group?: string;
  label: string;
  desc?: string;
}

const { id, num, group, label, desc } = Astro.props;
---

<section id={id} class="detail">
  <Crumb num={num} group={group} label={label} />
  <h2>{label}</h2>
  {desc && <p class="desc">{desc}</p>}
  <slot name="meta" />
  <slot />
</section>

<style>
  .detail {
    padding: 64px 64px 96px;
    max-width: 880px;
  }
  .detail h2 {
    font-size: 36px;
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin: 0;
    color: var(--color-ink-1);
  }
  .desc {
    margin: 14px 0 0;
    font-size: 16px;
    line-height: 1.55;
    color: var(--color-ink-3);
    max-width: 600px;
  }
  @media (max-width: 880px) {
    .detail {
      padding: 32px 24px;
    }
  }
</style>
