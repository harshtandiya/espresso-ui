---
import Crumb from "./Crumb.astro";
import MobileSectionPager from "@/components/mobile/MobileSectionPager.astro";

interface Props {
  id: string;
  num: string;
  group?: string;
  label: string;
  desc?: string;
}

const { id, num, group, label, desc } = Astro.props;
---

<section id={id} class="detail" data-section-num={num}>
  <div class="detail-head">
    <Crumb group={group} label={label} />
    <h2>{label}</h2>
    {desc && <p class="desc">{desc}</p>}
    <slot name="meta" />
  </div>
  <div class="detail-body">
    <slot />
    <MobileSectionPager id={id} />
  </div>
</section>

<style>
  .detail {
    padding: 64px 64px 96px;
    max-width: 880px;
  }
  .detail h2 {
    font-size: 36px;
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin: 0;
    color: var(--color-ink-1);
  }
  .desc {
    margin: 14px 0 0;
    font-size: 16px;
    line-height: 1.55;
    color: var(--color-ink-3);
    max-width: 600px;
  }

  @media (max-width: 768px) {
    .detail {
      padding: 0 0 32px;
      max-width: none;
      background: var(--color-surface);
    }
    .detail-head {
      padding: 8px var(--mobile-gutter, 20px) 18px;
      border-bottom: 1px solid var(--color-line-2);
    }
    .detail h2 {
      font-size: 26px;
      letter-spacing: -0.015em;
      line-height: 1.08;
    }
    .desc {
      margin: 10px 0 0;
      font-size: 14px;
      line-height: 1.5;
      max-width: none;
    }
    .detail-body {
      background: var(--color-surface);
    }
  }
</style>
