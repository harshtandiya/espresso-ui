---
import Crumb from "./Crumb.astro";
import MobileSectionPager from "@/components/mobile/MobileSectionPager.astro";

interface Props {
  id: string;
  num: string;
  group?: string;
  label: string;
  desc?: string;
}

const { id, num, group, label, desc } = Astro.props;
---

<section
  id={id}
  class="detail py-16 px-16 pb-24 max-w-[880px] max-md:p-0 max-md:max-w-none max-md:bg-(--color-surface)"
  data-section-num={num}
>
  <div
    class="detail-head max-md:px-[var(--mobile-gutter,20px)] max-md:pt-2 max-md:pb-[18px] max-md:border-b max-md:border-(--color-line-2)"
  >
    <Crumb group={group} label={label} />
    <h2
      class="text-4xl font-semibold tracking-tight leading-tight m-0 text-(--color-ink-1) max-md:text-[26px] max-md:leading-[1.08]"
    >
      {label}
    </h2>
    {
      desc && (
        <p class="desc mt-3.5 mb-0 text-base leading-relaxed text-(--color-ink-3) max-w-[600px] max-md:mt-2.5 max-md:text-sm max-md:leading-normal max-md:max-w-none">
          {desc}
        </p>
      )
    }
    <slot name="meta" />
  </div>
  <div class="detail-body max-md:bg-(--color-surface)">
    <slot />
    <MobileSectionPager id={id} />
  </div>
</section>
