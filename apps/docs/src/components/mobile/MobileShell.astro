---
import MobileTopNav from "./MobileTopNav.astro";
import MobileIndex from "./MobileIndex.astro";
---

<div class="mobile-index-layer" data-mobile-index-layer>
  <MobileTopNav />
  <MobileIndex />
</div>

<style>
  .mobile-index-layer {
    display: none;
    position: absolute;
    inset: 0;
    z-index: 3;
    background: var(--color-surface);
    flex-direction: column;
    transform: translateX(0);
    transition: transform 0.32s cubic-bezier(0.32, 0.72, 0.34, 1);
  }

  @media (max-width: 768px) {
    .mobile-index-layer {
      display: flex;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .mobile-index-layer {
      transition: none;
    }
  }
</style>
