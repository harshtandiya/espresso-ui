---
import { mobileSectionNeighbors, mobileSectionNumber } from "@/lib/sections";

interface Props {
  id: string;
}

const { id } = Astro.props;
const { prev, next } = mobileSectionNeighbors(id);
---

{
  (prev || next) && (
    <nav class="mobile-section-pager" aria-label="Section navigation">
      {prev ? (
        <button
          type="button"
          class="pager-btn prev"
          data-mobile-pick={prev.id}
          aria-label={`Previous: ${prev.label}`}
        >
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M15 18l-6-6 6-6" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          <span class="pager-num">{mobileSectionNumber(prev.id)}</span>
          <span class="pager-label">{prev.label}</span>
        </button>
      ) : (
        <span class="pager-gap" aria-hidden="true" />
      )}
      {next ? (
        <button
          type="button"
          class="pager-btn next"
          data-mobile-pick={next.id}
          aria-label={`Next: ${next.label}`}
        >
          <span class="pager-label">{next.label}</span>
          <span class="pager-num">{mobileSectionNumber(next.id)}</span>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M9 18l6-6-6-6" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </button>
      ) : (
        <span class="pager-gap" aria-hidden="true" />
      )}
    </nav>
  )
}

<style>
  .mobile-section-pager {
    display: none;
  }

  @media (max-width: 768px) {
    .mobile-section-pager {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
      margin: 28px var(--mobile-gutter, 20px) 0;
      padding: 20px 0 max(28px, env(safe-area-inset-bottom, 0px) + 12px);
      border-top: 1px solid var(--color-line-2);
    }

    .pager-gap {
      display: block;
    }

    .pager-btn {
      display: flex;
      align-items: center;
      gap: 8px;
      min-height: 52px;
      padding: 10px 12px;
      border: 1px solid var(--color-line-2);
      border-radius: 10px;
      background: var(--color-surface);
      cursor: pointer;
      font-family: inherit;
      text-align: left;
      transition:
        background-color 0.15s ease,
        transform 0.15s ease,
        border-color 0.15s ease;
    }

    .pager-btn:focus-visible {
      outline: none;
      box-shadow:
        0 0 0 2px var(--color-surface),
        0 0 0 4px var(--color-primary);
    }

    .pager-btn:active {
      background: var(--color-surface-2);
      border-color: var(--color-line);
      transform: scale(0.98);
    }

    .pager-btn.next {
      justify-content: flex-end;
      text-align: right;
    }

    .pager-btn svg {
      width: 16px;
      height: 16px;
      flex-shrink: 0;
      color: var(--color-ink-4);
    }

    .pager-num {
      flex-shrink: 0;
      min-width: 24px;
      font-family: var(--font-mono);
      font-size: 13px;
      font-weight: 600;
      color: var(--color-ink-2);
      font-variant-numeric: tabular-nums;
      letter-spacing: 0.02em;
    }

    .pager-label {
      flex: 1;
      min-width: 0;
      font-size: 14px;
      font-weight: 500;
      color: var(--color-ink-1);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .pager-btn.next .pager-label {
      flex: initial;
      text-align: right;
    }
  }

  @media (max-width: 768px) and (prefers-reduced-motion: reduce) {
    .pager-btn {
      transition: none;
    }

    .pager-btn:active {
      transform: none;
    }
  }
</style>
