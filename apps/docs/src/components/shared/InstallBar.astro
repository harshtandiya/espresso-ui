---
import { install } from "@/lib/site-copy";

interface Props {
  action?: "read" | "copy";
  navTarget?: string;
}

const { action = "copy", navTarget = "install" } = Astro.props;
---

<div class="install" data-install-bar>
  <span class="prompt">{install.prompt}</span>
  <code>
    <span class="tok-cmd">npx </span>espresso-ui<span class="tok-arg"> init</span>
  </code>
  {
    action === "read" ? (
      <button class="install-action" type="button" data-nav-item={navTarget}>
        Read
      </button>
    ) : (
      <button class="install-action" type="button" data-copy-install>
        Copy
      </button>
    )
  }
</div>

<style>
  .install {
    border: 1px solid var(--color-line);
    border-radius: 10px;
    background: var(--color-surface-2);
    padding: 4px 4px 4px 12px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .prompt {
    color: var(--color-ink-4);
    font-family: var(--font-mono);
    font-size: 13px;
  }
  .install code {
    flex: 1;
    font-family: var(--font-mono);
    font-size: 12.5px;
    color: var(--color-ink-1);
    white-space: nowrap;
    overflow: hidden;
  }
  .install code .tok-cmd {
    color: var(--color-ink-4);
  }
  .install code .tok-arg {
    color: var(--color-ink-3);
  }
  .install-action {
    height: 28px;
    padding: 0 10px;
    border-radius: 7px;
    border: 1px solid var(--color-line);
    background: var(--color-surface);
    font-size: 12px;
    font-weight: 500;
    color: var(--color-ink-2);
    font-family: inherit;
    cursor: pointer;
    flex-shrink: 0;
  }
  .install-action:hover {
    color: var(--color-ink-1);
    background: var(--color-surface-3);
  }
</style>
