{
  "name": "@espresso-ui/cli",
  "version": "0.1.2",
  "description": "Framework-agnostic UI component installer for React and Vue. Copies editable source into your project, shadcn-style.",
  "keywords": [
    "cli",
    "components",
    "design-system",
    "react",
    "shadcn",
    "tailwind",
    "ui",
    "vue"
  ],
  "homepage": "https://github.com/harshtandiya/espresso-ui#readme",
  "bugs": {
    "url": "https://github.com/harshtandiya/espresso-ui/issues"
  },
  "license": "MIT",
  "author": "Harsh Tandiya",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/harshtandiya/espresso-ui.git",
    "directory": "packages/cli"
  },
  "bin": {
    "espresso-ui": "dist/index.mjs"
  },
  "files": [
    "dist",
    "registry"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "bundle-registry": "tsx scripts/bundle-registry.ts",
    "build": "npm run bundle-registry && vp pack",
    "dev": "npm run bundle-registry && vp pack --watch",
    "pretest": "npm run bundle-registry",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "commander": "^13.1.0",
    "eta": "^3.5.0",
    "jsonc-parser": "^3.3.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@typescript/native-preview": "7.0.0-dev.20260316.1",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
