{
  "name": "@espresso-ui/cli",
  "version": "0.1.0",
  "description": "Framework-agnostic UI component CLI — copies components into your project as editable source code",
  "homepage": "https://github.com/harshtandiya/espresso-ui#readme",
  "bugs": {
    "url": "https://github.com/harshtandiya/espresso-ui/issues"
  },
  "license": "MIT",
