{
  "name": "@espresso-ui/tokens",
  "version": "0.0.0",
  "description": "Design tokens for espresso-ui: primitives, semantic CSS variables, and a Tailwind v4 theme.",
  "homepage": "https://github.com/harshtandiya/espresso-ui#readme",
  "bugs": {
    "url": "https://github.com/harshtandiya/espresso-ui/issues"
  },
  "license": "MIT",
  "author": "Harsh Tandiya",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/harshtandiya/espresso-ui.git",
    "directory": "packages/tokens"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./primitives.css": "./dist/primitives.css",
    "./tokens.css": "./dist/tokens.css",
    "./tailwind.css": "./dist/tailwind.css",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "generate": "tsx src/sd.config.ts",
    "build": "vp pack && pnpm generate",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@typescript/native-preview": "7.0.0-dev.20260316.1",
    "bumpp": "^11.0.1",
    "style-dictionary": "catalog:",
    "tsx": "catalog:",
    "typescript": "^5.9.3",
    "vite-plus": "^0.1.11"
  }
}
